#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan_composite;
        zmk,matrix_transform = &default_transform;
        zmk,split = &split;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;
//
// Row 0: 6L + 6R = 12    Row 3: 6L + 6R = 12
// Row 1: 6L + 6R = 12    Row 4: 5L + 5R = 10
// Row 2: 6L + 6R = 12    Row 5: 6L + 6R = 12
// Total: 70 keys

        map = <
// Row 0: L(c0-c5) R(c6-c11) = 12
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)   RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
// Row 1: L(c0-c5) R(c6-c11) = 12
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)   RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
// Row 2: L(c0-c5) R(c6-c11) = 12
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)   RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
// Row 3: L(c0-c5) R(c6-c11) = 12
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)   RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
// Row 4: L(c1-c5) R(c6-c10) = 10
RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)   RC(4,6) RC(4,7) RC(4,8) RC(4,9) RC(4,10)
// Row 5: L(c0-c5) R(c6-c11) = 12
RC(5,0) RC(5,1) RC(5,2) RC(5,3) RC(5,4) RC(5,5)   RC(5,6) RC(5,7) RC(5,8) RC(5,9) RC(5,10) RC(5,11)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";

        diode-direction = "col2row";
        columns = <6>;
        rows = <6>;
        row-gpios
            = <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 18 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 16 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };

    // Composite kscan: matrix keys + EC11 push button (added per-side in overlays)
    kscan_composite: kscan_composite {
        compatible = "zmk,kscan-composite";
        rows = <6>;
        columns = <12>;

        matrix {
            kscan = <&kscan0>;
        };

        // EC11 push button child is added in dactyl_right.overlay
    };

    right_encoder: encoder_right {
        compatible = "alps,ec11";
        a-gpios = <&pro_micro 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <80>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&right_encoder>;
        triggers-per-rotation = <20>;
    };

    split: split {
        compatible = "zmk,split-peripheral-left";
        status = "disabled";
    };
};
